---
import Layout from "../../layouts/Layout.astro";
import { mainNav } from "../../lib/nav";
import { getAllSystems } from "../../lib/collections";

const systems = await getAllSystems();
---

<Layout
  title="Sistemas · TALAZBRÁGOLES"
  description="Catálogo de sistemas de juego de rol documentados en las Talazbrágoles."
  canonicalPath="/sistemas"
  nav={mainNav}
>
  <div id="top" class="max-w-6xl mx-auto px-4 sm:px-8 py-14 sm:py-20">
    <header class="text-center max-w-3xl mx-auto">
      <h1 class="text-[clamp(2.2rem,6vw,4.5rem)] font-black tracking-[0.22em] text-black uppercase">
        SISTEMAS
      </h1>
      <p class="mt-6 text-base sm:text-xl text-black/80 leading-relaxed">
        Los juegos de rol que se jugaron —o de los que se habló— en las Talazbrágoles.
        Cada ficha incluye ediciones conocidas y fuentes verificables.
      </p>
    </header>

    <div class="mt-16 rounded-3xl border border-black/15 bg-white/45 p-10 text-center">
      <div class="text-xs uppercase tracking-[0.3em] text-black/60">Próximamente</div>
      <p class="mt-3 text-black/80">
        Esta sección se irá completando a medida que documentemos qué sistemas se jugaron en cada edición.
        {systems.length > 0 && ` Ya hay ${systems.length} ${systems.length === 1 ? "sistema" : "sistemas"} en el archivo.`}
      </p>
    </div>
  </div>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { mainNav } from "../../lib/nav";
import { getAllTimeline } from "../../lib/collections";

const entries = await getAllTimeline();

const categoryLabel: Record<string, string> = {
  edicion:    "Edición",
  prensa:     "Prensa",
  fundacion:  "Fundación",
  comunidad:  "Comunidad",
  sistema:    "Sistema",
  otra:       "Otro",
};
---

<Layout
  title="Cronología · TALAZBRÁGOLES"
  description="Línea temporal documentada de las Talazbrágoles y su contexto rolero."
  canonicalPath="/cronologia"
  nav={mainNav}
>
  <div id="top" class="max-w-4xl mx-auto px-4 sm:px-8 py-14 sm:py-20">
    <header class="text-center max-w-2xl mx-auto">
      <h1 class="text-[clamp(2.2rem,6vw,4.5rem)] font-black tracking-[0.22em] text-black uppercase">
        CRONOLOGÍA
      </h1>
      <p class="mt-6 text-base sm:text-xl text-black/80 leading-relaxed">
        Una línea temporal de eventos documentados. Solo aparece lo que tiene fuente.
      </p>
    </header>

    {entries.length === 0 ? (
      <div class="mt-16 rounded-3xl border border-black/15 bg-white/45 p-10 text-center">
        <div class="text-xs uppercase tracking-[0.3em] text-black/60">Pendiente de documentar</div>
        <p class="mt-3 text-black/80">
          Aún no hay suficientes entradas documentadas. El archivo crece con cada nueva fuente.
        </p>
      </div>
    ) : (
      <ol class="mt-16 relative border-l border-black/15 ml-4 space-y-10">
        {entries.map((e) => (
          <li class="ml-8">
            <div class="absolute -left-2 w-4 h-4 rounded-full border-2 border-black bg-[color:var(--paper)]"></div>
            <div class="text-xs uppercase tracking-[0.26em] text-black/60">
              {e.data.date}
              {e.data.precision !== "day" && ` (aprox.)`}
              <span class="ml-3 border border-black/15 px-2 py-0.5 rounded-full">
                {categoryLabel[e.data.category]}
              </span>
              {e.data.verified && (
                <span class="ml-2 text-black/40">✓ verificado</span>
              )}
            </div>
            <h2 class="mt-2 text-lg font-black tracking-[0.12em] uppercase text-black">
              {e.data.title}
            </h2>
            {e.data.description && (
              <p class="mt-2 text-black/80 leading-relaxed text-sm">{e.data.description}</p>
            )}
          </li>
        ))}
      </ol>
    )}
  </div>
</Layout>

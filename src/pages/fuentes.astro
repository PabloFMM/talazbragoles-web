---
/**
 * Página de fuentes.
 * Objetivo: transparencia total. Cada enlace incluye una nota "qué afirma".
 * Regla: si una fuente no se puede abrir (404, login, etc.), se indica.
 */

import Layout from "../layouts/Layout.astro";
import SourceCard from "../components/sources/SourceCard.astro";
import { mainNav } from "../lib/nav";
import { getAllSources } from "../lib/collections";

const sources = await getAllSources();

const pending = [
  "Programas oficiales o folletos escaneados (con fecha, sede y organizador).",
  "Carteles/flyers de cada edición.",
  "Recortes de prensa local que mencionen explícitamente Talazbrágoles.",
  "Fotos fechadas (o con contexto verificable) de las jornadas.",
  "Vídeos y publicaciones en redes que puedan citarse con URL estable.",
];

const description =
  "Listado de fuentes y enlaces: qué afirma cada una, qué falta y qué necesita documentación.";
---

<Layout
  title="Fuentes · TALAZBRÁGOLES"
  description={description}
  canonicalPath="/fuentes"
  nav={mainNav}
>
  <div id="top" class="max-w-6xl mx-auto px-4 sm:px-8 py-14 sm:py-20">
    <header class="text-center max-w-3xl mx-auto">
      <h1 class="text-[clamp(2.2rem,6vw,4.5rem)] font-black tracking-[0.22em] text-black uppercase">
        FUENTES
      </h1>
      <p class="mt-6 text-base sm:text-xl text-black/80 leading-relaxed">
        Aquí está el corazón documental del proyecto: enlaces reales y una nota simple para cada uno:
        <span class="font-semibold"> qué afirma</span>. Transparencia total, sin humo.
      </p>
    </header>

    <section class="mt-12 sm:mt-16">
      <div class="rounded-3xl border border-black/15 bg-white/55 p-6 sm:p-10">
        <div class="text-xs uppercase tracking-[0.3em] text-black/70">Listado (verificable)</div>
        <p class="mt-3 text-black/80 leading-relaxed">
          Si un enlace cae, lo señalamos. Si un dato es ambiguo, lo marcamos. Si aparece una fuente mejor, la priorizamos.
        </p>

        <ul class="mt-8 space-y-6">
          {sources.map((s) => (
            <SourceCard
              title={s.data.title}
              url={s.data.url}
              asserts={s.data.asserts}
              caveat={s.data.caveat}
              broken={s.data.broken}
              tags={s.data.tags}
            />
          ))}
        </ul>
      </div>
    </section>

    <section class="mt-10 sm:mt-14">
      <div class="rounded-3xl border border-black/15 bg-white/45 p-6 sm:p-10">
        <div class="text-xs uppercase tracking-[0.3em] text-black/70">Pendiente de documentar</div>
        <p class="mt-3 text-black/80 leading-relaxed">
          Este es el "botín" que buscamos para convertir memoria en archivo. Si tienes algo, aunque sea una foto borrosa,
          puede ser la pieza que faltaba.
        </p>
        <ul class="mt-6 space-y-3 text-black/80">
          {pending.map((p) => (
            <li class="flex gap-3">
              <span class="text-black/70" aria-hidden="true">✦</span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </div>
</Layout>

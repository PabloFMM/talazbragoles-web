---
/**
 * Página principal.
 * Tono: cálido y nostálgico, pero con rigor documental.
 * Regla de oro: si no hay fuente verificable, no se afirma como hecho.
 */

import Layout from "../layouts/Layout.astro";
import Hero from "../components/home/Hero.astro";
import HistoriaSection from "../components/home/HistoriaSection.astro";
import EdicionesPreview from "../components/home/EdicionesPreview.astro";
import RecuerdosSection from "../components/home/RecuerdosSection.astro";
import LegadoSection from "../components/home/LegadoSection.astro";
import { homeNav } from "../lib/nav";
import { getAllEditions, getAllSources } from "../lib/collections";

const editions = await getAllEditions();
const sources  = await getAllSources();

const description =
  "El legado de las Talazbrágoles: una web-archivo para conservar recuerdos roleros con cariño, rigor y fuentes.";
---

<Layout
  title="TALAZBRÁGOLES · El legado"
  description={description}
  canonicalPath="/"
  nav={homeNav}
>
  <div id="top" class="relative">
    <Hero />
    <HistoriaSection />
    <EdicionesPreview editions={editions} />
    <RecuerdosSection sources={sources} />
    <LegadoSection />
  </div>
</Layout>

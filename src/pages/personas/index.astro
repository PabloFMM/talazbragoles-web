---
import Layout from "../../layouts/Layout.astro";
import { mainNav } from "../../lib/nav";
import { getAllPeople } from "../../lib/collections";

const people = await getAllPeople();
---

<Layout
  title="Personas · TALAZBRÁGOLES"
  description="Organizadores, autores y figuras de la comunidad rolera que forman parte del legado Talazbrágoles."
  canonicalPath="/personas"
  nav={mainNav}
>
  <div id="top" class="max-w-6xl mx-auto px-4 sm:px-8 py-14 sm:py-20">
    <header class="text-center max-w-3xl mx-auto">
      <h1 class="text-[clamp(2.2rem,6vw,4.5rem)] font-black tracking-[0.22em] text-black uppercase">
        PERSONAS
      </h1>
      <p class="mt-6 text-base sm:text-xl text-black/80 leading-relaxed">
        Quienes organizaron, jugaron, diseñaron o dieron vida a las Talazbrágoles.
        Solo aparecen nombres con fuente verificable.
      </p>
    </header>

    <div class="mt-16 rounded-3xl border border-black/15 bg-white/45 p-10 text-center">
      <div class="text-xs uppercase tracking-[0.3em] text-black/60">Próximamente</div>
      <p class="mt-3 text-black/80">
        Esta sección se irá completando a medida que documentemos quiénes participaron.
        {people.length > 0 && ` Ya hay ${people.length} ${people.length === 1 ? "persona" : "personas"} en el archivo.`}
      </p>
    </div>
  </div>
</Layout>

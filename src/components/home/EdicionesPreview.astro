---
import type { CollectionEntry } from "astro:content";

interface Props {
  editions: CollectionEntry<"editions">[];
}
const { editions } = Astro.props;

const pendingCount = editions.filter((e) => e.data.status === "pendiente").length;
---
<section id="ediciones" class="py-16 sm:py-28 border-y border-black/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl sm:text-5xl text-black mb-4 sm:mb-6 uppercase tracking-[0.14em] font-black">Ediciones</h2>
      <p class="text-sm sm:text-base uppercase tracking-[0.3em] text-black/70">¿Qué encontrarás aquí?</p>
      <p class="mt-4 text-base sm:text-xl text-black/80 leading-relaxed">
        Una <span class="font-semibold">línea temporal</span> clara (año → sede → organizador → fuente).
        Cuando no haya dato verificable, lo verás marcado como pendiente.
      </p>
    </div>

    <div class="mt-12 rounded-3xl border border-black/15 bg-white/55 overflow-hidden">
      <div class="px-6 sm:px-8 py-6 border-b border-black/10 flex flex-col sm:flex-row gap-2 sm:gap-4 sm:items-center sm:justify-between">
        <div class="text-xl font-black tracking-[0.16em] text-black uppercase">Línea temporal</div>
        <a
          href="/ediciones"
          class="text-sm uppercase tracking-[0.26em] text-black/80 hover:text-black underline underline-offset-4 hover:decoration-[color:var(--accent)]"
        >
          Ver todas las ediciones →
        </a>
      </div>

      <div class="p-6 sm:p-8">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[760px] text-left">
            <thead class="text-xs uppercase tracking-[0.26em] text-black/70">
              <tr class="border-b border-black/10">
                <th class="py-4 pr-6">Año</th>
                <th class="py-4 pr-6">Sede</th>
                <th class="py-4 pr-6">Estado</th>
                <th class="py-4">Fuente principal</th>
              </tr>
            </thead>
            <tbody class="text-black/80">
              {editions.map((e) => (
                <tr class="border-b border-black/10 last:border-0">
                  <td class="py-5 pr-6 font-bold">
                    {e.data.year === "desconocida" ? "Pendiente" : e.data.year}
                  </td>
                  <td class="py-5 pr-6">{e.data.venue?.city ?? "Pendiente"}</td>
                  <td class="py-5 pr-6">
                    <span class:list={[
                      "text-[0.65rem] uppercase tracking-[0.22em] px-2 py-0.5 rounded-full border",
                      e.data.status === "documentada" && "border-black/30 bg-black/10",
                      e.data.status === "parcial"     && "border-black/20 bg-white/70",
                      e.data.status === "pendiente"   && "border-black/10 text-black/50",
                    ]}>
                      {e.data.status}
                    </span>
                  </td>
                  <td class="py-5">
                    {e.data.sourceIds.length > 0 ? (
                      <a
                        href="/fuentes"
                        class="text-black underline underline-offset-4 hover:decoration-[color:var(--accent)]"
                      >
                        {e.data.sourceIds[0]}
                      </a>
                    ) : (
                      <span class="text-black/40 text-sm">¿Tienes programa/cartel?</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {pendingCount > 0 && (
          <p class="mt-4 text-xs text-black/50 tracking-[0.2em] uppercase">
            {pendingCount} {pendingCount === 1 ? "edición pendiente" : "ediciones pendientes"} de documentar
          </p>
        )}
      </div>
    </div>
  </div>
</section>

---
import type { CollectionEntry } from "astro:content";

interface Props {
  edition: CollectionEntry<"editions">;
}
const { edition } = Astro.props;
const { year, title, status, venue } = edition.data;

const statusLabel = {
  documentada: "Documentada",
  parcial: "Parcial",
  pendiente: "Pendiente",
}[status];

const yearLabel = year === "desconocida" ? "Año desconocido" : String(year);
---
<article class="rounded-3xl border border-black/15 bg-white/55 p-6 sm:p-8">
  <div class="flex items-start justify-between gap-4">
    <div class="text-2xl font-black tracking-[0.16em] text-black uppercase">{yearLabel}</div>
    <span
      class:list={[
        "text-[0.65rem] uppercase tracking-[0.26em] px-3 py-1 rounded-full border",
        status === "documentada" && "border-black/30 bg-black text-white",
        status === "parcial"     && "border-black/20 bg-white/70 text-black/80",
        status === "pendiente"   && "border-black/15 bg-white/40 text-black/60",
      ]}
    >
      {statusLabel}
    </span>
  </div>
  <div class="mt-2 text-black/80 leading-snug">{title}</div>
  {venue?.city && (
    <div class="mt-3 text-xs uppercase tracking-[0.26em] text-black/60">{venue.city}</div>
  )}
  <a
    href={`/ediciones/${edition.id}`}
    class="mt-5 inline-flex text-sm text-black underline underline-offset-4 hover:decoration-[color:var(--accent)]"
  >
    Ver ficha →
  </a>
</article>
